ANTHROPIC_API_KEY=

# Set to 1/true to enable Flask debug mode (auto-reload, interactive debugger).
# Never enable in production.
FLASK_DEBUG=false

# Comma-separated list of allowed CORS origins. Defaults to the local Vite dev server.
CORS_ORIGINS=http://localhost:5173

# Per-IP rate limit for /api/chat (it calls a paid LLM per request).
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
